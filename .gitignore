# PoundCake .gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
# Keep frontend module libs tracked.
!ui/static/assets/js/lib/
!ui/static/assets/js/lib/**
ui/node_modules/
ui/dist/

# Virtual Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Logs
*.log
logs/*.log

# Database
*.db
*.sqlite3

# OS
.DS_Store
Thumbs.db

# mypy
.mypy_cache/
.dmypy.json
dmypy.json
*.tsbuildinfo

# ruff
.ruff_cache/

# Docker
docker-compose.override.yml

# Temporary
*.tmp
*.bak
*.backup

# Local configuration (keep .env.example!)
.env.local
*.local.yaml
*.local.yml

# StackStorm runtime key (generated)
.st2_api_key
config/st2_api_key

# ==============================================================================
# IMPORTANT: DO NOT IGNORE ALEMBIC MIGRATIONS!
# ==============================================================================
# Migration files MUST be tracked in version control
# Only ignore pycache within alembic
alembic/__pycache__/
alembic/**/__pycache__/

# Helm chart artifacts
# Chart tarballs are downloaded dependencies, not source files
helm/poundcake/charts/*.tgz
# NOTE: Chart.lock should be committed to pin versions

# Local agent handoff/context file (must stay local, do not commit)
AGENTS.md
agents.md
