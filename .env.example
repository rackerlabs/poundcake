# =============================================================================
# PoundCake Configuration
# =============================================================================
# All environment variables use the POUNDCAKE_ prefix

# =============================================================================
# Application Settings
# =============================================================================
POUNDCAKE_APP_NAME=PoundCake
POUNDCAKE_APP_VERSION=1.0.0
POUNDCAKE_DEBUG=false

# Server settings
POUNDCAKE_HOST=0.0.0.0
POUNDCAKE_PORT=8000
POUNDCAKE_WORKERS=4

# =============================================================================
# Database Settings (MySQL/MariaDB)
# =============================================================================
POUNDCAKE_DATABASE_URL=mysql+pymysql://poundcake:poundcake@mariadb:3306/poundcake
POUNDCAKE_DATABASE_ECHO=false

# =============================================================================
# Redis Settings
# =============================================================================
POUNDCAKE_REDIS_URL=redis://redis:6379/0
POUNDCAKE_REDIS_PASSWORD=
POUNDCAKE_ALERT_TTL_HOURS=24
POUNDCAKE_LOCK_TIMEOUT_SECONDS=300

# =============================================================================
# Celery Settings (Background Task Processing)
# =============================================================================
POUNDCAKE_CELERY_BROKER_URL=redis://redis:6379/1
POUNDCAKE_CELERY_RESULT_BACKEND=redis://redis:6379/2
POUNDCAKE_CELERY_TASK_TRACK_STARTED=true
POUNDCAKE_CELERY_TASK_TIME_LIMIT=300
POUNDCAKE_CELERY_WORKER_PREFETCH_MULTIPLIER=4
POUNDCAKE_CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# =============================================================================
# StackStorm Settings
# =============================================================================
POUNDCAKE_STACKSTORM_URL=https://stackstorm.example.com
POUNDCAKE_STACKSTORM_API_KEY=your-api-key-here
# Or use auth token instead of API key
# POUNDCAKE_STACKSTORM_AUTH_TOKEN=your-auth-token-here
POUNDCAKE_STACKSTORM_VERIFY_SSL=true

# =============================================================================
# Prometheus Settings
# =============================================================================
POUNDCAKE_PROMETHEUS_URL=http://prometheus.example.com:9090
POUNDCAKE_PROMETHEUS_VERIFY_SSL=true
POUNDCAKE_PROMETHEUS_RELOAD_ENABLED=false
# POUNDCAKE_PROMETHEUS_RELOAD_URL=http://prometheus:9090/-/reload

# Prometheus Operator CRD settings (default: enabled for Kubernetes)
POUNDCAKE_PROMETHEUS_USE_CRDS=true
POUNDCAKE_PROMETHEUS_CRD_NAMESPACE=monitoring
# POUNDCAKE_PROMETHEUS_CRD_LABELS='{"release": "prometheus-stack"}'

# =============================================================================
# Git Repository Settings (GitOps for Prometheus Rules)
# =============================================================================
POUNDCAKE_GIT_ENABLED=false
# POUNDCAKE_GIT_REPO_URL=https://github.com/yourorg/prometheus-config.git
# POUNDCAKE_GIT_BRANCH=main
# POUNDCAKE_GIT_RULES_PATH=prometheus/rules

# Git file organization
# POUNDCAKE_GIT_FILE_PER_ALERT=true
# POUNDCAKE_GIT_FILE_PATTERN={alert_name}.yaml

# Git authentication
# POUNDCAKE_GIT_TOKEN=ghp_your_github_token_here
# POUNDCAKE_GIT_SSH_KEY_PATH=/path/to/ssh/key

# Git commit author
# POUNDCAKE_GIT_USER_NAME=PoundCake
# POUNDCAKE_GIT_USER_EMAIL=poundcake@example.com

# Git provider for PR creation (github, gitlab, gitea, or none)
# POUNDCAKE_GIT_PROVIDER=github

# =============================================================================
# Mappings Settings
# =============================================================================
POUNDCAKE_MAPPINGS_PATH=config/mappings
POUNDCAKE_DEFAULT_TIMEOUT=300
POUNDCAKE_MAX_CONCURRENT_REMEDIATIONS=10

# =============================================================================
# Authentication Settings
# =============================================================================
POUNDCAKE_AUTH_ENABLED=false
POUNDCAKE_AUTH_SECRET_NAME=poundcake-admin
POUNDCAKE_AUTH_SECRET_NAMESPACE=poundcake
POUNDCAKE_AUTH_SESSION_TIMEOUT=86400

# Development auth fallback (only used if K8s secret unavailable)
# POUNDCAKE_AUTH_DEV_USERNAME=admin
# POUNDCAKE_AUTH_DEV_PASSWORD=admin

# =============================================================================
# Logging Settings
# =============================================================================
POUNDCAKE_LOG_LEVEL=INFO
POUNDCAKE_LOG_FORMAT=json

# =============================================================================
# Metrics Settings
# =============================================================================
POUNDCAKE_METRICS_ENABLED=true
POUNDCAKE_METRICS_PATH=/metrics

# =============================================================================
# CORS Settings
# =============================================================================
POUNDCAKE_CORS_ORIGINS=["*"]
POUNDCAKE_CORS_ALLOW_CREDENTIALS=true
POUNDCAKE_CORS_ALLOW_METHODS=["*"]
POUNDCAKE_CORS_ALLOW_HEADERS=["*"]
