# PoundCake Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed
# Defaults are provided for development environments

# Database Configuration
DB_ROOT_PASSWORD=rootpassword
DB_NAME=poundcake
DB_USER=poundcake
DB_PASSWORD=poundcake

# StackStorm Backend Passwords
# These are used by MongoDB and RabbitMQ for StackStorm
MONGO_PASSWORD=password
RABBITMQ_PASSWORD=password

# StackStorm Authentication
# Default credentials for st2admin user (matches htpasswd in docker/st2-config/htpasswd)
# Used by automated-setup.sh to authenticate and generate API keys
ST2_AUTH_USER=st2admin
ST2_AUTH_PASSWORD=Ch@ngeMe

# StackStorm API Key
# This is auto-generated by the stackstorm-bootstrap service on first run
# Leave empty - no manual setup required!
ST2_API_KEY=

# StackStorm Startup Configuration
# Maximum attempts to wait for StackStorm API to become ready during startup
# Each attempt waits POUNDCAKE_STACKSTORM_STARTUP_DELAY_SECONDS before retrying
POUNDCAKE_STACKSTORM_STARTUP_MAX_ATTEMPTS=120
POUNDCAKE_STACKSTORM_STARTUP_DELAY_SECONDS=2.0

# Service Polling Intervals (seconds)
OVEN_INTERVAL=5
TIMER_INTERVAL=10
PREP_CHEF_LIMIT=1
TIMER_LIMIT=1
POUNDCAKE_POLLER_HTTP_RETRIES=0
POUNDCAKE_CHEF_PATCH_RETRIES=3
POUNDCAKE_CHEF_PATCH_RETRY_BACKOFF_SECONDS=1.0
POUNDCAKE_CHEF_MISSING_EXECUTION_TIMEOUT_SECONDS=60

# External HTTP retries (StackStorm, Prometheus, Git providers, etc.)
POUNDCAKE_EXTERNAL_HTTP_RETRIES=2

# SLA & Timeout Configuration
# Buffer multiplier for expected_time_to_completion before triggering SLA alerts
# e.g., 0.2 means allow 20% over expected_time before marking as "Late"
SLA_BUFFER_PERCENT=0.2

# Dishwasher
DISHWASHER_STRICT_RECIPE_SYNC=false
DISHWASHER_INTERVAL=300
DISHWASHER_BOOTSTRAP_ATTEMPTS=10
DISHWASHER_BOOTSTRAP_RETRY_DELAY=5

# Application Metadata
APP_VERSION=1.0.0
POUNDCAKE_LOG_FORMAT=json
