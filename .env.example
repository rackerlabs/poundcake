# =============================================================================
# PoundCake Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed
# Defaults are provided for development environments

# Database Configuration
DB_ROOT_PASSWORD=rootpassword
DB_NAME=poundcake
DB_USER=poundcake
DB_PASSWORD=poundcake

# StackStorm Backend Passwords
# These are used by MongoDB and RabbitMQ for StackStorm
MONGO_PASSWORD=password
RABBITMQ_PASSWORD=password

# StackStorm Authentication
# Default credentials for st2admin user (matches htpasswd in docker/st2-config/htpasswd)
# Used by automated-setup.sh to authenticate and generate API keys
ST2_AUTH_USER=st2admin
ST2_AUTH_PASSWORD=Ch@ngeMe

# StackStorm API Key
# This is auto-generated by the st2client container on first run
# Leave empty - no manual setup required!
ST2_API_KEY=

# Service Polling Intervals (seconds)
OVEN_INTERVAL=5
TIMER_INTERVAL=10
OVEN_MAX_CONCURRENT_EXECUTIONS=10
OVEN_BATCH_LIMIT=10

# SLA & Timeout Configuration
# Buffer multiplier for expected_time_to_completion before triggering SLA alerts
# e.g., 0.2 means allow 20% over expected_time before marking as "Late"
SLA_BUFFER_PERCENT=0.2

# HTTPX Client Defaults (prefixed for PoundCake settings)
POUNDCAKE_HTTPX_TIMEOUT_SECONDS=30
POUNDCAKE_HTTPX_CONNECT_TIMEOUT_SECONDS=10
POUNDCAKE_HTTPX_READ_TIMEOUT_SECONDS=30
POUNDCAKE_HTTPX_WRITE_TIMEOUT_SECONDS=30
POUNDCAKE_HTTPX_MAX_CONNECTIONS=100
POUNDCAKE_HTTPX_MAX_KEEPALIVE=20
POUNDCAKE_HTTPX_RETRIES=2
POUNDCAKE_HTTPX_RETRY_BACKOFF_SECONDS=0.5
POUNDCAKE_HTTPX_RETRY_STATUSES=[429,500,502,503,504]

# Application Metadata
APP_VERSION=1.0.0
POUNDCAKE_LOG_FORMAT=json
