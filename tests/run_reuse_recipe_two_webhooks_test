#!/usr/bin/env bash
#  ___                        _  ____      _
# |  _ \ ___  _   _ _ __   __| |/ ___|__ _| | _____
# | |_) / _ \| | | | '_ \ / _` | |   / _` | |/ / _ \
# |  __/ (_) | |_| | | | | (_| | |__| (_| |   <  __/
# |_|   \___/ \__,_|_| |_|\__,_|\____\__,_|_|\_\___|
# Test: Reuse the same recipe/task signature across two webhook posts in one run
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib.sh"
start_test_target
register_cleanup_trap

TEST_TS=${TEST_TS:-$(generate_test_suffix)}
TEST_RECIPE=${TEST_RECIPE:-AutomatedReuseRecipe-${TEST_TS}}
REQ_ID_1=${REQ_ID_1:-AUTOMATED-REUSE-${TEST_TS}-1}
REQ_ID_2=${REQ_ID_2:-AUTOMATED-REUSE-${TEST_TS}-2}
FINGERPRINT_1=${FINGERPRINT_1:-AutomatedReuseRecipe-${TEST_TS}-1-$$-${RANDOM}}
FINGERPRINT_2=${FINGERPRINT_2:-AutomatedReuseRecipe-${TEST_TS}-2-$$-${RANDOM}}
TIMEOUT_SECONDS=${TIMEOUT_SECONDS:-90}
INTERVAL=${INTERVAL:-$POLL_INTERVAL_SEC}

require_cmd curl
require_cmd jq

log_info "Using recipe: ${TEST_RECIPE}"

# Find or create the expected core.local ingredient.
ING_TASK_KEY_TEMPLATE="local"
ING_ID=$(
  api_request_json GET \
    "${API_URL}/ingredients/?execution_target=core.local&task_key_template=${ING_TASK_KEY_TEMPLATE}" \
    | jq -r '.[0].id // empty'
)
if [ -z "${ING_ID}" ] || [ "${ING_ID}" = "null" ]; then
  ING_PAYLOAD=$(jq -n \
    --arg task_key_template "${ING_TASK_KEY_TEMPLATE}" \
    '{
      execution_target: "core.local",
      task_key_template: $task_key_template,
      is_blocking: true,
      expected_duration_sec: 30,
      timeout_duration_sec: 300,
      retry_count: 0,
      retry_delay: 5,
      on_failure: "stop"
    }')

  ING_ID=$(api_request_json POST "${API_URL}/ingredients/" "${ING_PAYLOAD}" | jq -r '.id')
fi

if [ -z "${ING_ID}" ] || [ "${ING_ID}" = "null" ]; then
  log_error "Failed to resolve ingredient core.local"
  exit 1
fi

# Create one two-step recipe with generated workflow.
RECIPE_PAYLOAD=$(jq -n \
  --arg name "${TEST_RECIPE}" \
  --arg desc "Automated recipe reuse test" \
  --argjson ing_id "${ING_ID}" \
  '{
    name: $name,
    description: $desc,
    enabled: true,
    recipe_ingredients: [
      {
        ingredient_id: $ing_id,
        step_order: 1,
        on_success: "continue",
        parallel_group: 0,
        depth: 0,
        execution_parameters_override: {cmd: "echo \"reuse step 1\""}
      },
      {
        ingredient_id: $ing_id,
        step_order: 2,
        on_success: "continue",
        parallel_group: 0,
        depth: 0,
        execution_parameters_override: {cmd: "echo \"reuse step 2\""}
      }
    ]
  }')

RECIPE_ID=$(api_request_json POST "${API_URL}/recipes/" "${RECIPE_PAYLOAD}" | jq -r '.id')

if [ -z "${RECIPE_ID}" ] || [ "${RECIPE_ID}" = "null" ]; then
  log_error "Failed to create recipe"
  exit 1
fi

post_webhook() {
  local req_id="$1"
  local fingerprint="$2"
  local payload
  payload=$(cat <<JSON
{
  "receiver": "poundcake",
  "status": "firing",
  "alerts": [
    {
      "status": "firing",
      "fingerprint": "${fingerprint}",
      "labels": {
        "alertname": "AutomatedReuseRecipeTest",
        "group_name": "${TEST_RECIPE}",
        "severity": "warning",
        "instance": "localhost:9090"
      },
      "annotations": {
        "summary": "Recipe reuse test",
        "description": "Recipe reuse test payload."
      },
      "startsAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
      "endsAt": null,
      "generatorURL": "http://prometheus:9090/graph"
    }
  ],
  "groupLabels": {"alertname": "AutomatedReuseRecipeTest"},
  "commonLabels": {"alertname": "AutomatedReuseRecipeTest", "group_name": "${TEST_RECIPE}"},
  "commonAnnotations": {},
  "externalURL": "http://alertmanager:9093",
  "version": "4",
  "groupKey": "{}:{alertname=\"AutomatedReuseRecipeTest\"}"
}
JSON
)
  REQUEST_ID="${req_id}" api_request_json POST "${API_URL}/webhook" "${payload}" >/dev/null
}

wait_for_dish() {
  local req_id="$1"
  local start now dishes count
  start=$(date +%s)
  while true; do
    dishes=$(api_request_json GET "${API_URL}/dishes?req_id=${req_id}")
    count=$(echo "${dishes}" | jq -r 'length')
    if [ "${count}" != "0" ]; then
      echo "${dishes}" | jq -r '.[0]'
      return 0
    fi
    now=$(date +%s)
    if [ $((now - start)) -ge "${TIMEOUT_SECONDS}" ]; then
      log_error "Timed out waiting for dish for req_id=${req_id}"
      return 1
    fi
    sleep "${INTERVAL}"
  done
}

wait_for_order_settled() {
  local req_id="$1"
  local start now orders count is_active processing_status
  start=$(date +%s)
  while true; do
    orders=$(api_request_json GET "${API_URL}/orders?req_id=${req_id}")
    count=$(echo "${orders}" | jq -r 'length')
    if [ "${count}" != "0" ]; then
      is_active=$(echo "${orders}" | jq -r '.[0].is_active')
      processing_status=$(echo "${orders}" | jq -r '.[0].processing_status')
      if [ "${is_active}" = "true" ] && [ "${processing_status}" = "waiting_clear" ]; then
        return 0
      fi
      if [ "${is_active}" = "false" ] && echo "${processing_status}" | grep -Eq "^(complete|failed|canceled)$"; then
        return 0
      fi
    fi
    now=$(date +%s)
    if [ $((now - start)) -ge "${TIMEOUT_SECONDS}" ]; then
      log_error "Timed out waiting for order to settle for req_id=${req_id}"
      return 1
    fi
    sleep "${INTERVAL}"
  done
}

wait_for_dish_ingredients() {
  local dish_id="$1"
  local start now ingredients count
  start=$(date +%s)
  while true; do
    ingredients=$(api_request_json GET "${API_URL}/dishes/${dish_id}/ingredients")
    count=$(echo "${ingredients}" | jq -r 'length')
    if [ "${count}" != "0" ]; then
      echo "${ingredients}"
      return 0
    fi
    now=$(date +%s)
    if [ $((now - start)) -ge "${TIMEOUT_SECONDS}" ]; then
      log_error "Timed out waiting for dish ingredients for dish_id=${dish_id}"
      return 1
    fi
    sleep "${INTERVAL}"
  done
}

build_task_signature() {
  local ingredients_json="$1"
  echo "${ingredients_json}" | jq -c 'map({
    task_key,
    execution_target,
    execution_engine
  }) | sort_by(.task_key, .execution_target, .execution_engine)'
}

log_info "Posting first webhook (${REQ_ID_1})..."
post_webhook "${REQ_ID_1}" "${FINGERPRINT_1}"
DISH1_JSON=$(wait_for_dish "${REQ_ID_1}")
RECIPE_ID_1=$(echo "${DISH1_JSON}" | jq -r '.recipe_id')
DISH_ID_1=$(echo "${DISH1_JSON}" | jq -r '.id')
INGREDIENTS_1=$(wait_for_dish_ingredients "${DISH_ID_1}")
TASK_SIG_1=$(build_task_signature "${INGREDIENTS_1}")
wait_for_order_settled "${REQ_ID_1}"

log_info "Posting second webhook (${REQ_ID_2})..."
post_webhook "${REQ_ID_2}" "${FINGERPRINT_2}"
DISH2_JSON=$(wait_for_dish "${REQ_ID_2}")
RECIPE_ID_2=$(echo "${DISH2_JSON}" | jq -r '.recipe_id')
DISH_ID_2=$(echo "${DISH2_JSON}" | jq -r '.id')
INGREDIENTS_2=$(wait_for_dish_ingredients "${DISH_ID_2}")
TASK_SIG_2=$(build_task_signature "${INGREDIENTS_2}")

if [ "${RECIPE_ID_1}" != "${RECIPE_ID_2}" ]; then
  log_error "Recipe was not reused: first=${RECIPE_ID_1} second=${RECIPE_ID_2}"
  exit 1
fi

if [ "${TASK_SIG_1}" != "${TASK_SIG_2}" ]; then
  log_error "Task signature was not reused"
  log_error "first=${TASK_SIG_1}"
  log_error "second=${TASK_SIG_2}"
  exit 1
fi

log_info "PASS: recipe and task signature reused across two webhook posts"
echo "recipe_id=${RECIPE_ID_1}"
echo "task_signature=${TASK_SIG_1}"
