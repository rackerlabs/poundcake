#!/usr/bin/env bash
#  ___                        _  ____      _
# |  _ \ ___  _   _ _ __   __| |/ ___|__ _| | _____
# | |_) / _ \| | | | '_ \ / _` | |   / _` | |/ / _ \
# |  __/ (_) | |_| | | | | (_| | |__| (_| |   <  __/
# |_|   \___/ \__,_|_| |_|\__,_|\____\__,_|_|\_\___|
#
# Suite: Run all e2e workflow-generation bash tests.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

TEST_SCRIPTS=(
  "${SCRIPT_DIR}/run_single_task_non_blocking_test"
  "${SCRIPT_DIR}/run_single_task_manual_order_test"
  "${SCRIPT_DIR}/run_multiple_tasks_non_blocking_test"
  "${SCRIPT_DIR}/run_multiple_tasks_with_blocking_test"
  "${SCRIPT_DIR}/run_reuse_recipe_two_webhooks_test"
)

echo "Running ${#TEST_SCRIPTS[@]} e2e workflow-generation tests..."
echo

passed=0
failed=0

for test_script in "${TEST_SCRIPTS[@]}"; do
  test_name="$(basename "${test_script}")"
  echo "=== ${test_name} ==="

  if "${test_script}"; then
    echo "PASS: ${test_name}"
    passed=$((passed + 1))
  else
    echo "FAIL: ${test_name}"
    failed=$((failed + 1))
  fi

  echo
done

echo "Suite complete: ${passed} passed, ${failed} failed"

if [ "${failed}" -gt 0 ]; then
  exit 1
fi
