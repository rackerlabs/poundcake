#!/usr/bin/env bash
#  ___                        _  ____      _
# |  _ \ ___  _   _ _ __   __| |/ ___|__ _| | _____
# | |_) / _ \| | | | '_ \ / _` | |   / _` | |/ / _ \
# |  __/ (_) | |_| | | | | (_| | |__| (_| |   <  __/
# |_|   \___/ \__,_|_| |_|\__,_|\____\__,_|_|\_\___|
#
# Suite: Run all e2e workflow-generation bash tests.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib.sh"
start_test_target
register_cleanup_trap
export TEST_TARGET_STARTED=1

TEST_SCRIPTS=(
  "${SCRIPT_DIR}/run_single_task_non_blocking_test"
  "${SCRIPT_DIR}/run_single_task_manual_order_test"
  "${SCRIPT_DIR}/run_single_task_webhook_counter_increment_test"
  "${SCRIPT_DIR}/run_multiple_tasks_non_blocking_test"
  "${SCRIPT_DIR}/run_multiple_tasks_with_blocking_test"
  "${SCRIPT_DIR}/run_host_down_expected_failure_test"
  "${SCRIPT_DIR}/run_reuse_recipe_two_webhooks_test"
  "${SCRIPT_DIR}/run_fallback_unmatched_alert_bakery_observation_test"
)

echo "Running ${#TEST_SCRIPTS[@]} e2e workflow-generation tests..."
echo
suite_start=$(date +%s)
log_info "Running ${#TEST_SCRIPTS[@]} e2e workflow-generation tests..."

passed=0
failed=0

for test_script in "${TEST_SCRIPTS[@]}"; do
  test_name="$(basename "${test_script}")"
  log_info "=== ${test_name} ==="

  if "${test_script}"; then
    log_info "PASS: ${test_name}"
    passed=$((passed + 1))
  else
    log_error "FAIL: ${test_name}"
    failed=$((failed + 1))
  fi

done

elapsed=$(( $(date +%s) - suite_start ))
log_info "Suite complete: ${passed} passed, ${failed} failed (elapsed=${elapsed}s)"

if [ "${failed}" -gt 0 ]; then
  exit 1
fi
