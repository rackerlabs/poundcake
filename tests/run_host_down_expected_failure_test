#!/usr/bin/env bash
# Negative test: host lookup fails, but workflow continues when on_failure=continue.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib.sh"
start_test_target
register_cleanup_trap

TEST_TS=${TEST_TS:-$(generate_test_suffix)}
TEST_RECIPE=${TEST_RECIPE:-HostDownExpectedFailure-${TEST_TS}}
REQ_ID=${REQ_ID:-HOSTDOWN-${TEST_TS}}

export API_URL TEST_RECIPE REQ_ID

# Step 1 intentionally fails host lookup; step 2 should still execute.
run_step "create two-step recipe (failure-continue)" \
  env IS_BLOCKING=true ING_ON_FAILURE=continue \
  STEP1_CMD='getent hosts no-such-host.invalid >/dev/null' \
  STEP2_CMD='echo "step 2 still runs"' \
  "${SCRIPT_DIR}/test_create_recipe_two_step.sh"
run_step "post webhook" "${SCRIPT_DIR}/test_post_webhook.sh"
run_step "wait for order" "${SCRIPT_DIR}/test_wait_for_order.sh"
run_step "wait for dishes" "${SCRIPT_DIR}/test_wait_for_dishes.sh"

log_info "Waiting for dish terminal status"
start=$(date +%s)
while true; do
  dish_json=$(api_request_json GET "${API_URL}/dishes?req_id=${REQ_ID}" | jq -cer 'sort_by(.created_at) | last')
  dish_id=$(echo "${dish_json}" | jq -r '.id')
  status=$(echo "${dish_json}" | jq -r '.processing_status')
  if echo "${status}" | grep -Eq '^(complete|failed|canceled)$'; then
    break
  fi
  now=$(date +%s)
  if [ $((now - start)) -ge "${TEST_TIMEOUT_SEC}" ]; then
    log_error "Timed out waiting for dish terminal status (dish_id=${dish_id}, status=${status})"
    exit 1
  fi
  sleep "${POLL_INTERVAL_SEC}"
done

ingredients=$(api_request_json GET "${API_URL}/dishes/${dish_id}/ingredients")

echo "${ingredients}" | jq .

failed_count=$(echo "${ingredients}" | jq -r '[.[] | select((.execution_status // "") | ascii_downcase == "failed")] | length')
non_failed_count=$(echo "${ingredients}" | jq -r '[.[] | select(((.execution_status // "") | ascii_downcase) != "failed")] | length')
failed_with_reason=$(echo "${ingredients}" | jq -r '[.[] | select(((.execution_status // "") | ascii_downcase) == "failed" and ((.error_message // "") | length > 0))] | length')

if [ "${failed_count}" -lt 1 ]; then
  log_error "Expected at least one failed ingredient for host-down ping"
  exit 1
fi
if [ "${failed_with_reason}" -lt 1 ]; then
  log_error "Expected failed ingredient to include an error_message"
  exit 1
fi
if [ "${non_failed_count}" -lt 1 ]; then
  log_error "Expected at least one non-failed ingredient to verify workflow continuation"
  exit 1
fi

log_info "Host-down negative test passed: failures were captured and later steps still executed"
