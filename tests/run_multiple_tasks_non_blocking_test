# Test: Run multiple tasks with manual order creation (blocking)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib.sh"
start_test_target
register_cleanup_trap

TEST_TS=${TEST_TS:-$(date +%s)}
TEST_RECIPE=${TEST_RECIPE:-AutomatedTestRecipe-${TEST_TS}}
REQ_ID=${REQ_ID:-AUTOMATED-${TEST_TS}}
FINGERPRINT=${FINGERPRINT:-AutomatedTestAlert-multi-non-blocking-${TEST_TS}-$$-${RANDOM}}

export API_URL TEST_RECIPE REQ_ID FINGERPRINT

run_step "create two-step recipe" \
  env IS_BLOCKING=false STEP1_CMD='sleep 2; echo "step 1"' STEP2_CMD='echo "step 2"' \
  "${SCRIPT_DIR}/test_create_recipe_two_step.sh"
run_step "post webhook" "${SCRIPT_DIR}/test_post_webhook.sh"
run_step "wait for order" "${SCRIPT_DIR}/test_wait_for_order.sh"
run_step "wait for dishes" "${SCRIPT_DIR}/test_wait_for_dishes.sh"
run_step "assert dish count" env EXPECTED_COUNT=1 "${SCRIPT_DIR}/test_assert_dish_count.sh"
run_step "assert non-blocking sequence" \
  env ASSERT_MODE=non_blocking "${SCRIPT_DIR}/test_assert_task_sequence.sh"
