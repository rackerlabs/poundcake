#!/usr/bin/env bash
#  ___                        _  ____      _
# |  _ \ ___  _   _ _ __   __| |/ ___|__ _| | _____
# | |_) / _ \| | | | '_ \ / _` | |   / _` | |/ / _ \
# |  __/ (_) | |_| | | | | (_| | |__| (_| |   <  __/
# |_|   \___/ \__,_|_| |_|\__,_|\____\__,_|_|\_\___|
# Test: Post two webhooks with the same fingerprint and assert order counter increments.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib.sh"
start_test_target
register_cleanup_trap

TEST_TS=${TEST_TS:-$(generate_test_suffix)}
TEST_RECIPE=${TEST_RECIPE:-AutomatedCounterRecipe-${TEST_TS}}
REQ_ID_1=${REQ_ID_1:-AUTOMATED-COUNTER-${TEST_TS}-1}
REQ_ID_2=${REQ_ID_2:-AUTOMATED-COUNTER-${TEST_TS}-2}
FINGERPRINT=${FINGERPRINT:-AutomatedCounterFingerprint-${TEST_TS}-$$-${RANDOM}}
TIMEOUT_SECONDS=${TIMEOUT_SECONDS:-$TEST_TIMEOUT_SEC}
INTERVAL=${INTERVAL:-$POLL_INTERVAL_SEC}

require_cmd curl
require_cmd jq

export API_URL TEST_RECIPE

wait_for_counter_increment() {
  local start now orders active active_count counter req2_count
  start=$(date +%s)

  while true; do
    orders=$(api_request_json GET "${API_URL}/orders?alert_group_name=${TEST_RECIPE}")
    active=$(echo "${orders}" | jq --arg fp "${FINGERPRINT}" '[.[] | select(.is_active == true and .fingerprint == $fp)]')
    active_count=$(echo "${active}" | jq -r 'length')
    counter=$(echo "${active}" | jq -r '.[0].counter // 0')
    req2_count=$(api_request_json GET "${API_URL}/orders?req_id=${REQ_ID_2}" | jq -r 'length')

    if [ "${active_count}" = "1" ] && [ "${counter}" -ge 2 ] && [ "${req2_count}" = "0" ]; then
      return 0
    fi

    now=$(date +%s)
    if [ $((now - start)) -ge "${TIMEOUT_SECONDS}" ]; then
      log_error "Timed out waiting for webhook counter increment"
      log_error "active_count=${active_count} counter=${counter} req2_count=${req2_count}"
      echo "${orders}" | jq >&2
      return 1
    fi

    sleep "${INTERVAL}"
  done
}

run_step "create recipe" env IS_BLOCKING=false "${SCRIPT_DIR}/test_create_recipe_single_step.sh"
run_step "post webhook #1" env REQ_ID="${REQ_ID_1}" FINGERPRINT="${FINGERPRINT}" "${SCRIPT_DIR}/test_post_webhook.sh"
run_step "wait for order #1" env REQ_ID="${REQ_ID_1}" "${SCRIPT_DIR}/test_wait_for_order.sh"
run_step "post webhook #2 (same fingerprint)" env REQ_ID="${REQ_ID_2}" FINGERPRINT="${FINGERPRINT}" "${SCRIPT_DIR}/test_post_webhook.sh"
run_step "assert counter incremented" wait_for_counter_increment
run_step "wait for dishes #1" env REQ_ID="${REQ_ID_1}" "${SCRIPT_DIR}/test_wait_for_dishes.sh"
run_step "assert dish count #1" env REQ_ID="${REQ_ID_1}" EXPECTED_COUNT=1 "${SCRIPT_DIR}/test_assert_dish_count.sh"

log_info "PASS: same-fingerprint webhook increments orders.counter"
