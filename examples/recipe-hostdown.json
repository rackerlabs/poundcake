{
  "name": "HostDown",
  "description": "Handle host down alerts with tiered response",
  "enabled": true,
  "ingredients": [
    {
      "task_id": "check-connectivity",
      "task_name": "Check Host Connectivity",
      "task_order": 1,
      "is_blocking": true,
      "st2_action": "core.local",
      "parameters": {
        "cmd": "ping -c 3 {{ alert.instance }}"
      },
      "expected_time_to_completion": 5,
      "timeout": 10,
      "retry_count": 2,
      "on_failure": "stop"
    },
    {
      "task_id": "check-service-a",
      "task_name": "Check Service A Status",
      "task_order": 2,
      "is_blocking": false,
      "st2_action": "core.remote",
      "parameters": {
        "hosts": "{{ alert.instance }}",
        "cmd": "systemctl status service-a"
      },
      "expected_time_to_completion": 3,
      "timeout": 10,
      "on_failure": "continue"
    },
    {
      "task_id": "check-service-b",
      "task_name": "Check Service B Status",
      "task_order": 3,
      "is_blocking": false,
      "st2_action": "core.remote",
      "parameters": {
        "hosts": "{{ alert.instance }}",
        "cmd": "systemctl status service-b"
      },
      "expected_time_to_completion": 3,
      "timeout": 10,
      "on_failure": "continue"
    },
    {
      "task_id": "restart-services",
      "task_name": "Restart Failed Services",
      "task_order": 4,
      "is_blocking": true,
      "st2_action": "core.remote_sudo",
      "parameters": {
        "hosts": "{{ alert.instance }}",
        "cmd": "systemctl restart service-a service-b"
      },
      "expected_time_to_completion": 30,
      "timeout": 60,
      "retry_count": 2,
      "on_failure": "stop"
    },
    {
      "task_id": "verify-recovery",
      "task_name": "Verify Services Recovered",
      "task_order": 5,
      "is_blocking": true,
      "st2_action": "core.remote",
      "parameters": {
        "hosts": "{{ alert.instance }}",
        "cmd": "curl -f http://localhost/health"
      },
      "expected_time_to_completion": 5,
      "timeout": 10,
      "on_failure": "continue"
    }
  ]
}
