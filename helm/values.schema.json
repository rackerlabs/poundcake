{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "poundcake",
  "type": "object",
  "required": ["secrets"],
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name"
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full resource name"
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" }
            }
          }
        ]
      },
      "description": "Image pull secrets for private registries"
    },
    "poundcakeImage": {
      "type": "object",
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "default": "poundcake"
        },
        "tag": {
          "type": "string",
          "default": ""
        },
        "digest": {
          "type": "string",
          "default": ""
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "Never", "IfNotPresent"],
          "default": "IfNotPresent"
        },
        "pullSecrets": {
          "type": "array",
          "description": "Image pull secrets for PoundCake workloads",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" }
                }
              }
            ]
          }
        },
        "securityContext": {
          "type": "object",
          "properties": {
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer" },
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean", "default": false },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "stackstormImage": {
      "type": "object",
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "default": "stackstorm/st2"
        },
        "tag": {
          "type": "string",
          "default": "3.9.0"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "Never", "IfNotPresent"],
          "default": "IfNotPresent"
        },
        "securityContext": {
          "type": "object",
          "properties": {
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer" },
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean", "default": false },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "uiImage": {
      "type": "object",
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "default": "poundcake-ui"
        },
        "tag": {
          "type": "string",
          "default": "latest"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "Never", "IfNotPresent"],
          "default": "IfNotPresent"
        },
        "containerPort": {
          "type": "integer",
          "default": 8080
        },
        "runtimeWritablePaths": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true }
          }
        },
        "securityContext": {
          "type": "object",
          "properties": {
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer" },
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean", "default": false },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "images": {
      "type": "object",
      "properties": {
        "mariadb": { "type": "string" },
        "mongodb": { "type": "string" },
        "rabbitmq": { "type": "string" },
        "redis": { "type": "string" },
        "alpine": { "type": "string" },
        "busybox": { "type": "string" },
        "kubectl": { "type": "string" }
      }
    },
    "utilitySecurityContext": {
      "type": "object",
      "description": "Container security context for utility/init containers and startup jobs",
      "properties": {
        "runAsNonRoot": { "type": "boolean", "default": true },
        "runAsUser": { "type": "integer", "default": 1000 },
        "allowPrivilegeEscalation": { "type": "boolean", "default": false },
        "readOnlyRootFilesystem": { "type": "boolean", "default": false },
        "capabilities": {
          "type": "object",
          "properties": {
            "drop": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "required": [
        "dbRootPassword",
        "dbName",
        "dbUser",
        "dbPassword",
        "mongoRootPassword",
        "mongoUsername",
        "mongoPassword",
        "rabbitmqUser",
        "rabbitmqPassword",
        "st2AuthUser",
        "st2AuthPassword"
      ],
      "properties": {
        "dbRootPassword": {
          "type": "string",
          "description": "Root password for MySQL/MariaDB"
        },
        "dbName": {
          "type": "string",
          "default": "poundcake"
        },
        "dbUser": {
          "type": "string",
          "default": "poundcake"
        },
        "dbPassword": {
          "type": "string",
          "description": "Database user password"
        },
        "mongoRootPassword": {
          "type": "string",
          "description": "Root password for MongoDB"
        },
        "mongoUsername": {
          "type": "string",
          "default": "stackstorm"
        },
        "mongoPassword": {
          "type": "string",
          "description": "MongoDB user password"
        },
        "rabbitmqUser": {
          "type": "string",
          "default": "stackstorm"
        },
        "rabbitmqPassword": {
          "type": "string",
          "description": "RabbitMQ user password"
        },
        "st2AuthUser": {
          "type": "string",
          "default": "st2admin"
        },
        "st2AuthPassword": {
          "type": "string",
          "description": "StackStorm authentication password"
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "storageClassName": {
          "type": "string",
          "description": "Default storage class for all PVCs"
        },
        "mariadb": {
          "type": "object",
          "properties": {
            "size": { "type": "string" },
            "accessMode": { "type": "string" },
            "storageClassName": { "type": "string" }
          }
        },
        "mongo": {
          "type": "object",
          "properties": {
            "size": { "type": "string" },
            "accessMode": { "type": "string" },
            "storageClassName": { "type": "string" }
          }
        },
        "rabbitmq": {
          "type": "object",
          "properties": {
            "size": { "type": "string" },
            "accessMode": { "type": "string" },
            "storageClassName": { "type": "string" }
          }
        },
        "redis": {
          "type": "object",
          "properties": {
            "size": { "type": "string" },
            "accessMode": { "type": "string" },
            "storageClassName": { "type": "string" }
          }
        },
        "stackstormPacks": {
          "type": "object",
          "description": "Shared volume for PoundCake-generated StackStorm pack content",
          "properties": {
            "size": { "type": "string" },
            "accessMode": { "type": "string" },
            "storageClassName": { "type": "string" }
          }
        },
        "config": {
          "type": "object",
          "properties": {
            "size": { "type": "string" },
            "accessMode": { "type": "string" },
            "storageClassName": { "type": "string" }
          }
        }
      }
    },
    "services": {
      "type": "object",
      "properties": {
        "api": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" },
            "publishNotReadyAddresses": { "type": "boolean", "default": true }
          }
        },
        "ui": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "stackstormApi": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "stackstormAuth": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "stackstormStream": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "stackstormWeb": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        }
      }
    },
    "stackstormApi": {
      "type": "object",
      "properties": {
        "readiness": {
          "type": "object",
          "properties": {
            "initialDelaySeconds": { "type": "integer", "minimum": 0, "default": 5 }
          }
        }
      }
    },
    "poundcakeApi": {
      "type": "object",
      "properties": {
        "readiness": {
          "type": "object",
          "properties": {
            "initialDelaySeconds": { "type": "integer", "minimum": 0, "default": 5 }
          }
        }
      }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "className": { "type": "string", "default": "envoyproxy" },
        "name": { "type": "string", "default": "poundcake-gateway" },
        "listeners": {
          "type": "object",
          "properties": {
            "api": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": true },
                "hostname": { "type": "string", "default": "api.poundcake.local" },
                "port": { "type": "integer", "default": 80 },
                "pathPrefix": { "type": "string", "default": "/" }
              }
            },
            "ui": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": true },
                "hostname": { "type": "string", "default": "ui.poundcake.local" },
                "port": { "type": "integer", "default": 80 },
                "pathPrefix": { "type": "string", "default": "/" }
              }
            }
          }
        }
      }
    },
    "stackstormComponents": {
      "type": "object",
      "description": "Optional StackStorm component toggles",
      "properties": {
        "register": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        },
        "stream": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        },
        "web": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        },
        "client": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "stackstormServices": {
      "type": "object",
      "description": "StackStorm service profile toggles (required and optional components)",
      "properties": {
        "mongodb": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "rabbitmq": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "redis": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "auth": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "api": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "actionrunner": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "rulesengine": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "workflowengine": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "scheduler": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "notifier": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": false } } },
        "garbagecollector": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "timersengine": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": false } } },
        "sensorcontainer": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": false } } },
        "register": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": false } } },
        "stream": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": false } } },
        "web": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": false } } },
        "client": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": false } } }
      }
    },
    "intervals": {
      "type": "object",
      "properties": {
        "chef": { "type": "string" },
        "prepChef": { "type": "string" },
        "timer": { "type": "string" },
        "dishwasher": { "type": "string" },
        "prepInterval": { "type": "string" }
      }
    },
    "logFormat": {
      "type": "string",
      "default": "console"
    },
    "resources": {
      "type": "object",
      "description": "Resource requests and limits for containers"
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector for pod placement"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Tolerations for pod placement"
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for pod placement"
    },
    "defaultResources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Security context for all pods",
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer" },
        "fsGroup": { "type": "integer" },
        "seccompProfile": {
          "type": "object",
          "properties": {
            "type": { "type": "string" }
          }
        }
      }
    },
    "infraSecurityContext": {
      "type": "object",
      "description": "Container security contexts for infrastructure services",
      "properties": {
        "mariadb": {
          "type": "object",
          "properties": {
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer", "default": 1000 },
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean" },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "mongodb": {
          "type": "object",
          "properties": {
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer", "default": 1000 },
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean" },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "rabbitmq": {
          "type": "object",
          "properties": {
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer", "default": 1000 },
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean" },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "redis": {
          "type": "object",
          "properties": {
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer", "default": 1000 },
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean" },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "startupHooks": {
      "type": "object",
      "description": "Startup hook cleanup behavior",
      "properties": {
        "parallelWait": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "failFast": { "type": "boolean", "default": true },
            "timeout": {
              "type": "string",
              "description": "kubectl wait timeout for startup gate checks",
              "default": "15m"
            }
          }
        },
        "gateLogging": {
          "type": "object",
          "description": "Logging controls for startup and init-container gate waits",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "intervalSeconds": { "type": "integer", "default": 30, "minimum": 1 },
            "prefix": { "type": "string", "default": "[gate]" }
          }
        },
        "cleanup": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "deleteSuccessful": { "type": "boolean", "default": true },
            "deleteFailed": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "pdb": {
      "type": "object",
      "description": "Pod disruption budget configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
